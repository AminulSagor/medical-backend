# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=medical_db

# Application Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# SMTP Configuration (for nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
SMTP_FROM=your_email@gmail.com

# OTP Configuration
OTP_EXPIRE_SEC=300
OTP_VERIFY_SESSION_SEC=300

# Bypass Email OTP (Development Only)
# Set to 'true' to bypass sending emails and use a default OTP code instead
# This is useful for development/testing without email service
BYPASS_EMAIL_OTP=false
DEFAULT_OTP_CODE=123456

# AWS S3 Configuration (for file uploads)
# Leave these blank if not using S3 - file upload will be disabled
# Get credentials from AWS IAM console
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
STRIPE_SECRET_KEY=sk_test_your_secret_key

STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/checkout/success?session_id={CHECKOUT_SESSION_ID}

STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/checkout/cancel

# AWS SES Configuration (for file uploads)
AWS_REGION=your_region
SES_FROM_EMAIL=Your_from_email
SES_CONTACT_RECEIVER_EMAIL=your_receiver_email
SES_ENABLE_AUTO_REPLY=false
# After production access is approved change it to: SES_ENABLE_AUTO_REPLY=true

FRONTEND_URL=http://localhost:3000

NEWSLETTER_WEBHOOK_SECRET=your_super_secret


# INVOICE Configuration
INVOICE_SUPPLIER_NAME=Texas Airway Institute
INVOICE_SUPPLIER_EIN=12-3456789
INVOICE_SUPPLIER_EMAIL=billing@texasairway.com
INVOICE_SUPPLIER_PHONE=+1-555-100-2000
INVOICE_SUPPLIER_ADDRESS_LINE1=1234 Medical Center Dr, Suite 500
INVOICE_SUPPLIER_ADDRESS_LINE2=
INVOICE_SUPPLIER_CITY=Houston
INVOICE_SUPPLIER_STATE=TX
INVOICE_SUPPLIER_ZIP=77030
INVOICE_PAYMENT_TERMS=Due on receipt
INVOICE_BANK_INFO=ACH / bank remittance available upon request
